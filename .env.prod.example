# Copy to .env.prod on your server and fill in. Used by docker-compose.prod.yml.

# ── Database ──────────────────────────────────────────
POSTGRES_USER=essentials
POSTGRES_PASSWORD=CHANGE-ME-strong-password
POSTGRES_DB=essentials_sales

# ── Core ──────────────────────────────────────────────
NODE_ENV=production
# Your real public domain (the reverse proxy / load balancer terminates HTTPS)
CORS_ORIGIN=https://sales.essentials-egy.com
PUBLIC_BASE_URL=https://sales.essentials-egy.com

# ── Auth (generate long random strings!) ──────────────
JWT_ACCESS_SECRET=CHANGE-ME-long-random
JWT_REFRESH_SECRET=CHANGE-ME-long-random
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ── Integrations (same values you used locally) ───────
SHOPIFY_SHOP=
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_API_VERSION=2024-07
SHOPIFY_WEBHOOK_SECRET=

ODOO_URL=https://essentials1.odoo.com
ODOO_DB=essentials1
ODOO_USERNAME=
ODOO_PASSWORD=
ODOO_CACHE_TTL=300
ODOO_POLL_SECONDS=60

BOSTA_BASE_URL=https://app.bosta.co/api/v2
BOSTA_API_KEY=
BOSTA_WEBHOOK_SECRET=

# ── Notifications (optional) ──────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Essentials <no-reply@essentials.eg>
SMS_PROVIDER_URL=
SMS_PROVIDER_KEY=
WHATSAPP_PROVIDER_URL=
WHATSAPP_PROVIDER_KEY=
