// Essentials Sales System — Prisma schema
// Replaces Odoo Sales. Inventory/products/warehouses live in Odoo (read/write via API)
// and are NOT modeled here as the source of truth — only referenced by Odoo ids/SKU.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────── Auth & RBAC ─────────────────────────────

enum Role {
  ADMIN
  SALES_MANAGER
  SALES_AGENT
  CUSTOMER
}

/// Internal staff users (Admin / Sales Manager / Sales Agent).
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role      @default(SALES_AGENT)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?

  refreshTokens RefreshToken[]
  orderEvents   OrderEvent[]
  customerNotes CustomerNote[]
  approvedOrders Order[]       @relation("OrderApprover")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
}

/// Rotating refresh tokens. Stores a hash, never the raw token.
model RefreshToken {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String?
  customerId String?
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer   Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  revokedAt  DateTime?
  replacedBy String?
  userAgent  String?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([customerId])
}

// ───────────────────────────── Customers ─────────────────────────────

model Customer {
  id            String   @id @default(cuid())
  // Customer portal auth (optional — many COD customers never log in)
  email         String?  @unique
  passwordHash  String?
  phone         String?
  firstName     String?
  lastName      String?
  acceptsMarketing Boolean @default(false)
  notes         String?   // free-text quick note; richer notes in CustomerNote

  shopifyCustomerId String? @unique

  addresses    Address[]
  orders       Order[]
  customerNotes CustomerNote[]
  refreshTokens RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([phone])
  @@index([email])
}

enum AddressType {
  SHIPPING
  BILLING
}

model Address {
  id         String      @id @default(cuid())
  customerId String
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type       AddressType @default(SHIPPING)
  isDefault  Boolean     @default(false)

  firstName  String?
  lastName   String?
  phone      String?
  line1      String
  line2      String?
  city       String
  district   String?     // for Egypt / Bosta zoning
  governorate String?    // Egyptian governorate
  country    String      @default("EG")
  zip        String?

  shippingOrders Order[]  @relation("OrderShippingAddress")
  billingOrders  Order[]  @relation("OrderBillingAddress")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
}

/// Timestamped, authored notes attached to a customer (CRM-lite).
model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  authorId   String?
  author     User?    @relation(fields: [authorId], references: [id])
  body       String
  createdAt  DateTime @default(now())

  @@index([customerId])
}

// ───────────────────────────── Orders ─────────────────────────────

enum OrderStatus {
  PENDING_REVIEW
  APPROVED
  SENT_TO_ODOO
  PROCESSING
  SHIPPED
  DELIVERED
  // side statuses
  ON_HOLD
  CANCELLED
  RETURNED
  PAYMENT_PENDING
  REJECTED
}

enum OrderSource {
  SHOPIFY
  MANUAL
}

model Order {
  id            String      @id @default(cuid())
  /// Human-friendly order number, e.g. ES-10042
  orderNumber   String      @unique
  source        OrderSource @default(SHOPIFY)
  status        OrderStatus @default(PENDING_REVIEW)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  shippingAddressId String?
  shippingAddress   Address? @relation("OrderShippingAddress", fields: [shippingAddressId], references: [id])
  billingAddressId  String?
  billingAddress    Address? @relation("OrderBillingAddress", fields: [billingAddressId], references: [id])

  currency      String   @default("EGP")
  subtotal      Decimal  @db.Decimal(12, 2)
  shippingTotal Decimal  @default(0) @db.Decimal(12, 2)
  discountTotal Decimal  @default(0) @db.Decimal(12, 2)
  taxTotal      Decimal  @default(0) @db.Decimal(12, 2)
  grandTotal    Decimal  @db.Decimal(12, 2)

  customerNote  String?
  internalNote  String?
  holdReason    String?
  cancelReason  String?

  // Shopify linkage
  shopifyOrderId   String? @unique
  shopifyOrderName String?

  // Odoo linkage (the delivery/picking we created — NOT a sale order)
  odooPickingId    Int?
  odooPushedAt     DateTime?

  approvedById String?
  approvedBy   User?     @relation("OrderApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  /// Set atomically when shipment creation is claimed, to prevent two callers
  /// (manual button + poller) from both creating a Bosta shipment.
  shipmentClaimedAt DateTime?

  /// Set atomically the first time the "arrived at warehouse" notification is
  /// sent for this order, so the courier resending the same warehouse status
  /// (webhook + polling can both report it) never notifies the customer twice.
  warehouseNotifiedAt DateTime?

  items      OrderItem[]
  payments   Payment[]
  shipments  Shipment[]
  events     OrderEvent[]

  placedAt  DateTime  @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([status])
  @@index([customerId])
  @@index([placedAt])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  sku         String  // join key to Odoo (default_code)
  name        String
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2)
  totalPrice  Decimal @db.Decimal(12, 2)

  // Resolved Odoo references (snapshot at ingest time)
  odooProductId Int?
  shopifyLineItemId String?

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([sku])
}

/// Immutable audit log of every order status change / significant action.
model OrderEvent {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus OrderStatus?
  toStatus   OrderStatus?
  type       String      // e.g. STATUS_CHANGE, NOTE, ODOO_PUSH, SHIPMENT_CREATED
  message    String?
  actorId    String?
  actor      User?       @relation(fields: [actorId], references: [id])
  metadata   Json?
  createdAt  DateTime    @default(now())

  @@index([orderId])
}

// ───────────────────────────── Payments ─────────────────────────────

enum PaymentMethod {
  COD
  CARD
  WALLET
  BANK_TRANSFER
  OTHER
}

enum PaymentStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  REFUNDED
  PARTIALLY_REFUNDED
  FAILED
}

model Payment {
  id        String        @id @default(cuid())
  orderId   String
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method    PaymentMethod @default(COD)
  status    PaymentStatus @default(PENDING)
  amount    Decimal       @db.Decimal(12, 2)
  amountPaid Decimal      @default(0) @db.Decimal(12, 2)
  currency  String        @default("EGP")
  reference String?       // gateway / Shopify transaction id
  paidAt    DateTime?

  refunds   Refund[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([status])
}

model Refund {
  id        String   @id @default(cuid())
  paymentId String
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  amount    Decimal  @db.Decimal(12, 2)
  reason    String?
  reference String?
  createdAt DateTime @default(now())

  @@index([paymentId])
}

// ───────────────────────────── Shipments (Bosta) ─────────────────────────────

enum ShipmentStatus {
  CREATED
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  RETURNED
  CANCELLED
  EXCEPTION
}

model Shipment {
  id        String         @id @default(cuid())
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courier   String         @default("BOSTA")
  status    ShipmentStatus @default(CREATED)

  trackingNumber String?  @unique  // Bosta tracking number
  bostaDeliveryId String? @unique  // Bosta internal delivery id
  trackingUrl    String?
  /// Public, shareable token for the /track portal (unguessable).
  publicToken    String   @unique @default(cuid())

  currentLocation String?
  estimatedDeliveryAt DateTime?

  events ShipmentEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([trackingNumber])
}

/// Timeline entries for a shipment (driven by Bosta webhooks/polling).
model ShipmentEvent {
  id          String         @id @default(cuid())
  shipmentId  String
  shipment    Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  status      ShipmentStatus
  description String?
  location    String?
  occurredAt  DateTime
  raw         Json?
  createdAt   DateTime       @default(now())

  @@index([shipmentId])
}

// ───────────────────────────── Integration plumbing ─────────────────────────────

/// Raw inbound webhook envelope — dedup + replay + audit.
model WebhookEvent {
  id          String   @id @default(cuid())
  provider    String   // SHOPIFY | BOSTA
  topic       String   // e.g. orders/create
  externalId  String?  // provider event/resource id for dedup
  payload     Json
  hmacValid   Boolean  @default(false)
  processedAt DateTime?
  error       String?
  attempts    Int      @default(0)
  createdAt   DateTime @default(now())

  @@unique([provider, topic, externalId])
  @@index([processedAt])
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model Notification {
  id         String              @id @default(cuid())
  channel    NotificationChannel
  status     NotificationStatus  @default(PENDING)
  to         String              // email / phone
  template   String              // ORDER_APPROVED, SHIPMENT_CREATED, ...
  payload    Json?
  orderId    String?
  customerId String?
  error      String?
  sentAt     DateTime?
  createdAt  DateTime            @default(now())

  @@index([status])
  @@index([orderId])
}

/// Atomic counters (e.g. human-friendly order-number sequence). Incremented via
/// a single UPDATE so concurrent callers never get the same value.
model Counter {
  id    String @id
  value Int    @default(0)
}

/// Cache of Odoo product/stock reads to avoid hammering the Odoo API.
model OdooProductCache {
  sku          String   @id          // default_code
  odooProductId Int     @unique
  name         String
  price        Decimal? @db.Decimal(12, 2)
  qtyAvailable Decimal? @db.Decimal(12, 2)
  warehouseId  Int?
  refreshedAt  DateTime @default(now())
}
