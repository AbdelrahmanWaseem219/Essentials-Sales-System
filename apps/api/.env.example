# ── Core ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# ── Database / cache ──────────────────────────────────
DATABASE_URL=postgresql://essentials:essentials@localhost:5432/essentials_sales?schema=public
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900            # 15m (seconds)
JWT_REFRESH_TTL=2592000       # 30d (seconds)

# ── Shopify ───────────────────────────────────────────
SHOPIFY_SHOP=your-shop.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxx
SHOPIFY_API_VERSION=2024-07
SHOPIFY_WEBHOOK_SECRET=shpss_xxx   # used for HMAC verification

# ── Odoo (Inventory only) ─────────────────────────────
ODOO_URL=https://odoo.example.com
ODOO_DB=essentials
ODOO_USERNAME=integration@essentials.eg
ODOO_PASSWORD=odoo-api-key
ODOO_CACHE_TTL=300            # seconds
ODOO_POLL_SECONDS=60         # poll Odoo; validated Delivery → auto Bosta shipment (0=off)

# ── Bosta ─────────────────────────────────────────────
BOSTA_BASE_URL=https://app.bosta.co/api/v2
BOSTA_API_KEY=xxx
BOSTA_WEBHOOK_SECRET=xxx
BOSTA_PICKUP_ADDRESS_ID=         # default pickup location id in Bosta

# ── Notifications ─────────────────────────────────────
# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Essentials <no-reply@essentials.eg>
# SMS / WhatsApp (provider-agnostic; e.g. Twilio / local EG gateway)
SMS_PROVIDER_URL=
SMS_PROVIDER_KEY=
WHATSAPP_PROVIDER_URL=
WHATSAPP_PROVIDER_KEY=

# Public base URL used to build shareable tracking links
PUBLIC_BASE_URL=http://localhost:3000
